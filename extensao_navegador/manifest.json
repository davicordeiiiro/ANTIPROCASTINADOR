{
  "manifest_version": 3,
  "name": "Antiprocrastinador Tech",
  "version": "1.1.0",
  "description": "Cronômetro Pomodoro dark premium com bloqueador de distrações.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Antiprocrastinador"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
